# === Banco de Dados ===
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# === Autenticação (NextAuth v5) ===
# Gere com: openssl rand -hex 32
AUTH_SECRET=
# URL base da aplicação (mude em produção)
AUTH_URL=http://localhost:3000
# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# GitHub OAuth (opcional — descomente quando necessário)
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# === API Ignav (Passagens Aéreas) ===
# https://ignav.com — crie uma conta e gere sua API Key
IGNAV_API_KEY=ignav_xxx

# === Admin (seed) ===
# Usado pelo db:seed para criar o admin inicial
ADMIN_EMAIL=admin@pricetracker.dev
ADMIN_PASSWORD=Admin@123

# === Deploy Vercel (apenas CI/CD) ===
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
